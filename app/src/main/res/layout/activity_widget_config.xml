<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- Animated Background Blobs (different angles from login page) -->
    <View
        android:id="@+id/bg_blob_widget_1"
        android:layout_width="380dp"
        android:layout_height="380dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-140dp"
        android:layout_marginTop="-140dp"
        android:background="@drawable/nav_pill_background"
        android:backgroundTint="#1E2196F3" />

    <View
        android:id="@+id/bg_blob_widget_2"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-90dp"
        android:layout_marginBottom="-90dp"
        android:background="@drawable/nav_pill_background"
        android:backgroundTint="#152196F3" />

    <View
        android:id="@+id/bg_blob_widget_3"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="-80dp"
        android:background="@drawable/nav_pill_background"
        android:backgroundTint="#0D2196F3" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="?android:attr/textColorPrimary"
            app:title="" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_config_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customize Your Widget"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="28sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tv_live_preview_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Live Preview"
                android:textColor="?attr/secondaryTextColor"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"
                android:alpha="0.7" />

            <!-- Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/preview_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:id="@+id/preview_outer_container"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="?attr/cardBackgroundColor">

                    <FrameLayout
                        android:layout_width="383dp"
                        android:layout_height="187dp"
                        android:layout_gravity="center"
                        android:scaleX="0.8"
                        android:scaleY="0.8">
                        <include layout="@layout/med_widget" />
                    </FrameLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Controls Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/controls_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeColor="?attr/cardStrokeColor"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/cardBackgroundColor">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Background Color Label — theme-aware -->
                    <TextView
                        android:id="@+id/tv_bg_color_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background Color"
                        android:textColor="?android:attr/textColorPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <SeekBar
                        android:id="@+id/sb_bg_hue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="360"
                        android:progress="207"
                        android:layout_marginBottom="24dp" />

                    <!-- Background Opacity Label — theme-aware -->
                    <TextView
                        android:id="@+id/tv_bg_opacity_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background Opacity"
                        android:textColor="?android:attr/textColorPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <SeekBar
                        android:id="@+id/sb_bg_opacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="255"
                        android:progress="255"
                        android:layout_marginBottom="24dp" />

                    <!-- Text Color Label — theme-aware -->
                    <TextView
                        android:id="@+id/tv_text_color_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Text and Icons Color"
                        android:textColor="?android:attr/textColorPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <SeekBar
                        android:id="@+id/sb_text_hue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="360"
                        android:progress="0"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_text_white"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep text white (Better contrast)"
                        android:textColor="?android:attr/textColorPrimary"
                        android:checked="true"
                        android:layout_marginBottom="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="ADD TO HOME SCREEN"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="16dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>