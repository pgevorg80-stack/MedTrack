<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.GevorgPetrosyan" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">#2196F3</item>
        <item name="colorAccent">#2196F3</item>

        <!-- General UI Colors (Dark) -->
        <item name="android:windowBackground">#121212</item>
        <item name="android:textColorPrimary">#FFFFFF</item>

        <!-- NAVIGATION BAR DARK MODE LOGIC: Dark background with Blue icons -->
        <item name="navBarBackground">#1A2530</item>
        <item name="navBarContentColor">#2196F3</item>

        <!-- Dialog Buttons -->
        <item name="android:buttonBarButtonStyle">@style/BlueButtonStyle</item>
    </style>

    <style name="BlueButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#2196F3</item>
    </style>
</resources>